// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "provider": "Claude",
      "model": "claude-sonnet-4-5-20250929-thinking"
    },
    "model_parameters": []
  },
  "language_models": {
    "openai_compatible": {
      "Claude": {
        "api_url": "https://cc.honoursoft.cn",
        "available_models": [
          {
            "name": "claude-sonnet-4-5-20250929-thinking",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      },
      "Cerebras": {
        "api_url": "https://api.cerebras.ai/v1",
        "available_models": [
          {
            "name": "qwen-3-32b",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      }
    }
  },
  "theme": "Ayu Dark",
  "buffer_font_family": "MesloLGL Nerd Font Mono",
  "buffer_font_size": 14,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 15,
  "icon_theme": "Catppuccin Frappé",

  "base_keymap": "JetBrains",
  "buffer_line_height": { "custom": 1.4 },
  "buffer_font_features": { "calt": false },
  "buffer_font_weight": 300,
  "toolbar": { "breadcrumbs": false, "quick_actions": false },
  "project_panel": { "entry_spacing": "comfortable" },
  "tabs": { "file_icons": true },
  "format_on_save": "off",
  "hard_tabs": true
}
